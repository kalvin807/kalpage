---
interface Props {
  title: string;
  date: string;
}

const { title, date } = Astro.props;
---

<div class="relative border-l border-accent-30 pb-6 pl-5 last:pb-0">
  <span class="absolute top-5 -left-[3px] size-[5px] bg-accent" aria-hidden="true"></span>
  <article class="border border-accent-30 bg-bg-card p-4 transition-colors hover:border-accent-50">
    <span class="mb-2 inline-block border border-accent-30 px-2 py-0.5 font-mono text-xs uppercase tracking-wide text-accent tabular-nums">{date}</span>
    <h3 class="m-0 mb-1 font-heading text-base font-semibold text-balance text-text-heading">{title}</h3>
    <div class="timeline-desc text-[0.9rem] leading-relaxed text-pretty text-text">
      <slot />
    </div>
  </article>
</div>
